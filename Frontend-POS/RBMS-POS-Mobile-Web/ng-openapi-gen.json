{
  "$schema": "node_modules/ng-openapi-gen/ng-openapi-gen-schema.json",
  "input": "swagger.json",
  "output": "src/app/core/api",
  "ignoreUnusedModels": false,
  "removeStaleFiles": true,
  "enumStyle": "alias",
  "skipJsonSuffix": false,
  "modelIndex": true,
  "serviceIndex": true,
  "apiModule": false,
  "excludeTags": [],
  "serviceSuffix": "Service",
  "modelSuffix": ""
}
