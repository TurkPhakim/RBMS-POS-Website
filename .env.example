# ═══════════════════════════════════════════════════════════════
# RBMS-POS — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy ไฟล์นี้เป็น .env แล้วแก้ค่าทุกตัว:
#   cp .env.example .env && nano .env
#
# ห้าม commit .env เข้า git!
# ═══════════════════════════════════════════════════════════════

# === Domain ===
# Production: ใช้ nip.io ถ้าไม่มี domain จริง (เช่น 161.246.199.200.nip.io)
# Local: ใช้ localhost
DOMAIN=localhost
CERTBOT_EMAIL=your-email@example.com

# === SQL Server ===
# Password ต้องมี: ตัวพิมพ์ใหญ่ + ตัวพิมพ์เล็ก + ตัวเลข + สัญลักษณ์ (อย่างน้อย 8 ตัว)
MSSQL_SA_PASSWORD=YourStr0ng!Pass
MSSQL_MEMORY_LIMIT_MB=1024

# === สำหรับ docker-compose.dev.yml (dev mode เดิม) ===
SA_PASSWORD=YourStr0ng!Pass

# === JWT ===
# สร้างด้วย: openssl rand -base64 48
JWT_SECRET=CHANGE-ME-TO-RANDOM-64-CHARS-MINIMUM

# === MinIO (S3 Storage) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=rbms-pos-files

# === SMTP (Email — ถ้าใช้) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
