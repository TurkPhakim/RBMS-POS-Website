# === RBMS-POS Docker Development Dependencies ===
# Copy ไฟล์นี้เป็น .env แล้วแก้ค่าตามต้องการ
# cp .env.example .env

# SQL Server
# Password ต้องมี: ตัวพิมพ์ใหญ่ + ตัวพิมพ์เล็ก + ตัวเลข + อักขระพิเศษ (อย่างน้อย 8 ตัว)
SA_PASSWORD=YourStr0ng!Pass

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=rbms-pos-files
